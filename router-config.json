{
  "providers": {
    "mistral": {
      "billing": "pay_per_token"
    },
    "ollama": {
      "billing": "subscription"
    },
    "openrouter": {
      "billing": "pay_per_token",
      "free_models": [
        "openrouter/qwen/qwen3-4b:free",
        "openrouter/openai/gpt-4o-mini:free",
