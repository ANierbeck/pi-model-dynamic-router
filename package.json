{
  "name": "@anierbeck/pi-model-dynamic-router",
  "version": "1.1.0",
  "description": "Pi extension that routes model groups to concrete models. Balances intelligence, cost, and availability.",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "main": "dist/index.js",
  "bin": {
    "pi-model-router": "./dist/index.js"
  },
  "pi": {
    "extension": "./dist/index.js",
    "commands": [
      "router"
    ]
  },
  "scripts": {
    "build": "tsc && cp router-defaults.yaml router-config.json model-map.yaml dist/",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_INTEGRATION=true vitest run test/classifier.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "model-router",
    "llm",
    "ai"
  ],
  "author": "ANierbeck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ANierbeck/pi-model-dynamic-router.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/",
    "skills/",
    "PI.md",
    "README.md"
  ],
  "dependencies": {
    "yaml": "^2.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "execa": "^9.6.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
