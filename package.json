{
  "name": "pi-model-dynamic-router",
  "version": "1.1.0",
  "description": "Pi extension that routes model groups to concrete models. Balances intelligence, cost, and availability.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pi-model-router": "./dist/index.js"
  },
  "pi": {
    "extension": "./dist/index.js",
    "commands": ["router"]
  },
  "scripts": {
    "build": "tsc && cp src/*.js dist/ && cp index.js dist/ && cp router-defaults.yaml router-config.json model-map.yaml dist/",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "TEST_INTEGRATION=true vitest run test/classifier.test.ts"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "model-router",
    "llm",
    "ai"
  ],
  "author": "Aaron Canary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-canary/pi-model-router.git"
  },
  "files": [
    "index.ts",
    "router-config.json",
    "router-defaults.yaml",
    "model-map.yaml",
    "skills/",
    "src/",
    "PI.md",
    "README.md"
  ],
  "dependencies": {
    "yaml": "^2.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "execa": "^9.6.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
